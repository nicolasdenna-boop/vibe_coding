# Copy this file to .env and fill in real values. Never commit .env.

# Gemini (used by /rank for CV/job fit scoring)
GEMINI_API_KEY=

# Adzuna (https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed (https://www.reed.co.uk/developers)
REED_API_KEY=

# Careerjet (http://developers.careerjet.com)
CAREERJET_AFFILIATE_ID=

# Jooble (https://jooble.org/api/about)
JOOBLE_API_KEY=

# SerpAPI (https://serpapi.com) — powers /scan-preview and /scan-and-alert
SERPAPI_KEY=

# SendGrid (https://sendgrid.com) — sends the /scan-and-alert email digest
SENDGRID_API_KEY=
ALERT_EMAIL_TO=nicolas.denna@gmail.com
ALERT_EMAIL_FROM=
